# Copy to terraform.tfvars and fill in.

aws_region   = "us-east-1"
owner_tag    = "your.name@example.com"
key_name     = "my-ec2-keypair-name"
your_ip_cidr = "0.0.0.0/0"   # narrow to your IP for production: "1.2.3.4/32"

# Cross-account Bedrock credentials (Mezmo Bedrock account 627029844476).
# Same pattern as the existing Bella Vista demo — provisioned through Mezmo IAM,
# not the demo box's instance profile.
bedrock_access_key_id     = ""
bedrock_secret_access_key = ""

# Optional — point at the S3 bucket holding pre-built artifacts so a fresh
# EC2 boot picks up aura-cli (and, in phase 2, a pre-built aura-web-server)
# without needing manual scp. The bootstrap script step 3b fetches
# s3://<bucket>/staging/aura-cli on first boot if this is set; otherwise
# aura-cli is skipped (demo still works via curl). For account 627029844476,
# the validated bucket is "aura-sregym-demo-staging".
# demo_s3_bucket = "aura-sregym-demo-staging"

# Pin SREGym commit + AURA ref. Default is "main" for both. Set to specific
# SHAs once we lock the demo to a known-good combination. Ignored entirely
# when ami_id is set (the AMI has both pre-fetched).
# sregym_commit_sha = "main"
# aura_git_ref      = "main"

# Pre-baked AMI. When set, boot time drops from ~25 min to ~2-3 min because
# rust + AURA binary + SREGym checkout + docker images + kind cluster +
# helm release are all pre-installed. The bootstrap still runs idempotently
# to rewrite systemd units and re-inject the fault. For account 627029844476
# the validated AMI is ami-0e1820c60f160a3bf.
# ami_id = "ami-0e1820c60f160a3bf"
